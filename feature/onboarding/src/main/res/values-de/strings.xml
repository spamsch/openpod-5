    <string name="onboarding_profile_target_high_hint">Hoher Bereich: 80 \u2013 200 mg/dL</string>
    <string name="onboarding_profile_target_error_high_ge_low">Der hohe Zielwert muss mindestens dem niedrigen Zielwert entsprechen</string>
