    <string name="onboarding_profile_all_day">(ganzt\u00e4gig)</string>
    <string name="onboarding_profile_time_range">%1$s \u2013 %2$s</string>

    <!-- Profile Screen: DIA -->
    <string name="onboarding_profile_dia_title">Insulinwirkdauer</string>
    <string name="onboarding_profile_dia_description">Wie lange Insulin nach einem Bolus in deinem K\u00f6rper aktiv bleibt. Dies beeinflusst, wie der Bolusrechner bereits wirkendes Insulin (Insulin on Board) ber\u00fccksichtigt.</string>
    <string name="onboarding_profile_dia_unit">Stunden</string>
    <string name="onboarding_profile_dia_value">%1$s Stunden</string>
    <string name="onboarding_profile_dia_min">2,0 Std.</string>
    <string name="onboarding_profile_dia_max">5,0 Std.</string>
    <string name="onboarding_profile_dia_presets_title">G\u00c4NGIGE INSULINTYPEN</string>
    <string name="onboarding_profile_dia_presets_hint">Tippe auf einen Insulintyp, um die empfohlene Wirkdauer einzustellen. Passe nach Anweisung deines Arztes an.</string>
    <string name="onboarding_profile_dia_slider_a11y">Insulinwirkdauer, aktuell %1$s Stunden. Einstellbar von 2,0 bis 5,0 Stunden.</string>
    <string name="onboarding_profile_dia_error">Die Wirkdauer muss zwischen 2,0 und 5,0 Stunden liegen</string>

    <!-- Profile Screen: IC Ratio -->
    <string name="onboarding_profile_ic_title">Insulin-Kohlenhydrat-Verh\u00e4ltnis</string>
    <string name="onboarding_profile_ic_description">Wie viele Gramm Kohlenhydrate eine Einheit Insulin abdeckt. Beispiel: 1:10 bedeutet, dass 1 Einheit 10g Kohlenhydrate abdeckt.</string>
    <string name="onboarding_profile_ic_label">1 E :</string>
    <string name="onboarding_profile_ic_suffix">g</string>
    <string name="onboarding_profile_ic_range_hint">G\u00fcltiger Bereich: 1 \u2013 150 g/E</string>
    <string name="onboarding_profile_ic_error">Gib f\u00fcr jedes Zeitsegment ein Verh\u00e4ltnis zwischen 1 und 150 ein</string>
    <string name="onboarding_profile_ic_summary">1:%1$d g/E</string>

    <!-- Profile Screen: Correction Factor -->
    <string name="onboarding_profile_cf_title">Korrekturfaktor</string>
    <string name="onboarding_profile_cf_description">Wie stark eine Einheit Insulin deinen Blutzucker senkt. Auch Insulinempfindlichkeitsfaktor (ISF) genannt.</string>
    <string name="onboarding_profile_cf_label">1 E senkt BZ um</string>
    <string name="onboarding_profile_cf_suffix">mg/dL</string>
    <string name="onboarding_profile_cf_range_hint">G\u00fcltiger Bereich: 1 \u2013 400 mg/dL pro E</string>
    <string name="onboarding_profile_cf_error">Gib f\u00fcr jedes Zeitsegment einen Korrekturfaktor zwischen 1 und 400 ein</string>
    <string name="onboarding_profile_cf_summary">%1$d mg/dL pro E</string>

    <!-- Profile Screen: Target Glucose -->
    <string name="onboarding_profile_target_title">Ziel-Blutzucker</string>
    <string name="onboarding_profile_target_description">Dein gew\u00fcnschter Blutzuckerbereich. Der Bolusrechner nutzt diesen, um Korrekturdosen zu berechnen.</string>
    <string name="onboarding_profile_target_low">Niedrig</string>
    <string name="onboarding_profile_target_high">Hoch</string>
