    <!-- Profile Screen: Basal Program -->
    <string name="onboarding_profile_basal_title">Basalprogramm</string>
    <string name="onboarding_profile_basal_description">Deine Hintergrund-Insulinabgaberate. Diese l\u00e4uft kontinuierlich, um deinen Blutzucker zwischen den Mahlzeiten stabil zu halten.</string>
    <string name="onboarding_profile_basal_info">Dieses Basalprogramm wird nur im manuellen Modus verwendet. Im automatischen Modus passt der Pod die Basalabgabe selbst an.</string>
    <string name="onboarding_profile_basal_name_label">Programmname</string>
    <string name="onboarding_profile_basal_default_name">Programm 1</string>
