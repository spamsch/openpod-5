<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Welcome Screen -->
    <string name="onboarding_welcome_app_name">OpenPod</string>
    <string name="onboarding_welcome_tagline">Open-Source-Pod-Forschung</string>
    <string name="onboarding_welcome_description">Ein unabh\u00e4ngiges Forschungs- und Interoperabilit\u00e4tsprojekt f\u00fcr Omnipod 5 Insulinpods. Diese Software ist nicht f\u00fcr den medizinischen Einsatz zugelassen.</string>
    <string name="onboarding_welcome_research_warning">WARNUNG: Diese Software ist nicht von der FDA oder einer anderen Zulassungsbeh\u00f6rde genehmigt. Sie wird weder von Insulet Corporation noch von Dexcom unterst\u00fctzt oder ist mit diesen verbunden. Verwenden Sie diese Software nicht zur Insulinabgabe an eine Person. Nur f\u00fcr Forschung und Interoperabilit\u00e4tsstudien.</string>
    <string name="onboarding_welcome_get_started">Los geht\'s</string>
    <string name="onboarding_welcome_get_started_a11y">Los geht\'s. OpenPod einrichten.</string>

    <!-- Permissions Screen -->
    <string name="onboarding_permissions_title">Berechtigungen</string>
    <string name="onboarding_permissions_subtitle">OpenPod ben\u00f6tigt einige Berechtigungen, um mit deinem Pod zu kommunizieren und dich sicher zu halten.</string>
    <string name="onboarding_permissions_bluetooth_title">Bluetooth</string>
    <string name="onboarding_permissions_bluetooth_description">Erforderlich, um deinen Omnipod 5 Pod zu finden und mit ihm zu kommunizieren. Ohne Bluetooth kann die App nicht funktionieren.</string>
    <string name="onboarding_permissions_location_title">Standort</string>
    <string name="onboarding_permissions_location_description">Android ben\u00f6tigt Standortzugriff, um nach Bluetooth-Ger\u00e4ten in der N\u00e4he zu suchen. OpenPod verfolgt oder speichert deinen Standort niemals.</string>
    <string name="onboarding_permissions_notifications_title">Benachrichtigungen</string>
    <string name="onboarding_permissions_notifications_description">Erhalte Warnungen f\u00fcr Pod-Alarme, niedrigen F\u00fcllstand, Ablaufwarnungen und Abgabe-Updates \u2014 auch wenn dein Bildschirm aus ist.</string>
    <string name="onboarding_permissions_grant_bluetooth">Bluetooth erlauben</string>
    <string name="onboarding_permissions_grant_bluetooth_a11y">Bluetooth-Berechtigung erteilen</string>
    <string name="onboarding_permissions_grant_location">Standort erlauben</string>
    <string name="onboarding_permissions_grant_location_a11y">Standort-Berechtigung erteilen</string>
    <string name="onboarding_permissions_grant_notifications">Benachrichtigungen erlauben</string>
    <string name="onboarding_permissions_grant_notifications_a11y">Benachrichtigungs-Berechtigung erteilen</string>
    <string name="onboarding_permissions_granted">Erteilt</string>
    <string name="onboarding_permissions_granted_a11y">%1$s Berechtigung. Erteilt.</string>
    <string name="onboarding_permissions_continue">Weiter</string>
    <string name="onboarding_permissions_continue_disabled_a11y">Weiter. Alle erforderlichen Berechtigungen m\u00fcssen zuerst erteilt werden.</string>
    <string name="onboarding_permissions_denied_snackbar">Berechtigung verweigert. Tippe, um die Einstellungen zu \u00f6ffnen.</string>
    <string name="onboarding_permissions_open_settings">Einstellungen \u00f6ffnen</string>
    <string name="onboarding_permissions_notifications_auto_granted">Benachrichtigungen sind auf deiner Android-Version standardm\u00e4\u00dfig aktiviert</string>

    <!-- Profile Screen: Common -->
    <string name="onboarding_profile_title">Insulinprofil</string>
    <string name="onboarding_profile_subtitle">Gib die Werte aus deinem Rezept ein. \u00dcberpr\u00fcfe sie mit deinem Arzt.</string>
    <string name="onboarding_profile_back">Zur\u00fcck</string>
    <string name="onboarding_profile_back_a11y">Zum vorherigen Schritt</string>
