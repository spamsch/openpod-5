    <string name="pairing_discover_troubleshoot_1">Make sure the pod is filled</string>
    <string name="pairing_discover_troubleshoot_2">Move your phone closer</string>
    <string name="pairing_discover_troubleshoot_3">Check that Bluetooth is enabled</string>
    <string name="pairing_discover_scan_again">Scan Again</string>
    <string name="pairing_discover_scanning_description">Searching for pods nearby</string>
    <string name="pairing_discover_pod_description">%1$s, signal %2$s, ID %3$s</string>

    <!-- Step 3: Connect & Authenticate -->
    <string name="pairing_connect_title">Connecting to Pod\u2026</string>
    <string name="pairing_connect_time_hint">This may take up to 30 seconds.</string>
    <string name="pairing_connect_step_ble">BLE connected</string>
    <string name="pairing_connect_step_services">Services discovered</string>
