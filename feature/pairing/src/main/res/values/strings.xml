    <!-- Step 1: Fill Pod -->
    <string name="pairing_fill_title">Fill Your Pod</string>
    <string name="pairing_fill_instruction_1">Remove the pod from its packaging</string>
    <string name="pairing_fill_instruction_2">Fill the syringe with insulin</string>
    <string name="pairing_fill_instruction_3">Insert the syringe into the pod\'s fill port until it clicks</string>
    <string name="pairing_fill_instruction_4">Push the plunger slowly until the pod beeps (minimum 85 units)</string>
    <string name="pairing_fill_button">Pod Is Filled</string>
    <string name="pairing_fill_illustration_description">Illustration of a pod being filled with a syringe</string>

    <!-- Step 2: Discover Pod -->
    <string name="pairing_discover_title">Searching for Pods\u2026</string>
    <string name="pairing_discover_hint">Hold your phone close to the pod.</string>
    <string name="pairing_discover_found_header">FOUND PODS</string>
