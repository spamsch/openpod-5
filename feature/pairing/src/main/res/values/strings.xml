    <string name="pairing_apply_title">Apply Pod to Your Body</string>
    <string name="pairing_apply_instruction_1">Choose an infusion site (abdomen, upper arm, thigh, or lower back)</string>
    <string name="pairing_apply_instruction_2">Clean the site with alcohol</string>
    <string name="pairing_apply_instruction_3">Remove the adhesive backing</string>
    <string name="pairing_apply_instruction_4">Press the pod firmly onto your skin</string>
    <string name="pairing_apply_site_header">WHERE DID YOU PLACE IT?</string>
    <string name="pairing_apply_button">Pod Is Applied</string>
